# Flask Environment Variables
FLASK_APP=app.py
FLASK_ENV=development

# Application Secrets (Change these in production!)
SECRET_KEY=change-this-super-secret-key
JWT_SECRET_KEY=change-this-jwt-secret-key

# Database URL
# By default, the application will use SQLite, so you don't need to change this for local testing.
# For PostgreSQL: postgresql://username:password@localhost:5432/soc_db
DATABASE_URL=sqlite:///soc_assistant.db

# Optional AI API Key (If you want to use a real LLM for the AI Analysis instead of the local heuristic engine)
# OPENAI_API_KEY=your_openai_api_key_here
